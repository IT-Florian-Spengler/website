# Automatisches HTTPS via Let's Encrypt.
# Domain(s) und E-Mail werden aus der .env geladen (SITE_DOMAIN, ACME_EMAIL).
{
	email {$ACME_EMAIL}
}

{$SITE_DOMAIN} {
	encode zstd gzip
	reverse_proxy website:80

	# HSTS: Browser erzwingen HTTPS für ein Jahr
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
}
